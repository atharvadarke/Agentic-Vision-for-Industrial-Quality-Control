# =============================================================================
# .env.example — Agentic Vision for Industrial Quality Control
# =============================================================================
# Copy this file to .env and fill in the values before running:
#
#   cp .env.example .env
#
# NEVER commit the actual .env to version control (it's in .gitignore).
# =============================================================================

# ── Required ─────────────────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Optional Overrides ────────────────────────────────────────────────────────
# These have sensible defaults; only set them if you need to override.

# LLM settings
# GROQ_MODEL=llama-3.3-70b-versatile
# LLM_TEMPERATURE=0.1

# Paths (default to project-relative paths; override for custom mount points)
# RAW_DATA_DIR=/app/data/raw
# MODEL_PATH=/app/models/anomaly_detector.joblib
# DB_PATH=/app/data/defect_history.db

# Pipeline tuning
# LATENCY_THRESHOLD_SECONDS=0.5
# ISOLATION_FOREST_CONTAMINATION=0.05
# ISOLATION_FOREST_N_ESTIMATORS=100

# Logging
# LOG_LEVEL=INFO
